---
import Layout from '../../layouts/Layout.astro';
import ProjectForm from '../../components/ProjectForm.svelte';
import arrowLeftIcon from '../../assets/icons/arrow-left.svg?url';
---

<Layout title="Novo Projeto — Gerenciador de Projetos">
  <div class="mb-2">
    <a href="/" class="text-base text-brand hover:underline flex items-center gap-2">
      <img src={arrowLeftIcon} alt="Voltar" class="w-4 h-4" />
      Voltar
    </a>
  </div>
  <h1 class="text-2xl font-semibold text-empty-title mb-8">Novo projeto</h1>
  <ProjectForm client:load />
</Layout>
